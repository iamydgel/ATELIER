# Variables d'environnement — L'Atelier Local AI Console
# Copiez ce fichier en .env et ajustez selon votre configuration.
# Le fichier .env réel est gitignoré : ne le commitez jamais.

# Répertoire de données local
LOCALAI_DATA_DIR=~/.localai

# Clé secrète HMAC pour les sessions (minimum 32 caractères aléatoires)
LOCALAI_SECRET_KEY=replaceme-with-32-bytes-min-secret-string

# Durée de vie des sessions en heures
LOCALAI_SESSION_TTL_HOURS=24

# Moteur d'inférence actif : lmstudio | llamacpp
LOCALAI_INFERENCE_BACKEND=lmstudio

# LM Studio — serveur local OpenAI-compatible
LMSTUDIO_HOST=127.0.0.1
LMSTUDIO_PORT=1234

# llama.cpp — serveur alternatif (si LOCALAI_INFERENCE_BACKEND=llamacpp)
LLAMACPP_HOST=127.0.0.1
LLAMACPP_PORT=8081
